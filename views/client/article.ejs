<%- include('../partials/header') %>

<div class="page-header" style="padding-top:100px;">
    <div class="container">
        <div style="margin-bottom:16px;"><a href="/blog" style="color:rgba(255,255,255,.6);font-size:.9rem;">← Blog</a></div>
        <span class="badge badge-teal" style="margin-bottom:12px;"><%= article.type %></span>
        <h1><%= article.titre %></h1>
        <p style="color:rgba(255,255,255,.6);margin-top:12px;">
            Par <%= article.admin_name %> —
            <%= new Date(article.published_at || article.created_at).toLocaleDateString('fr-FR', {day:'2-digit',month:'long',year:'numeric'}) %>
        </p>
    </div>
</div>

<section class="section">
    <div class="container" style="max-width:800px;">
        <% if (article.image_url) { %>
        <img src="<%= article.image_url %>" alt="<%= article.titre %>"
            class="article-cover"
            style="width:100%;height:380px;object-fit:cover;border-radius:var(--radius-lg);margin-bottom:40px;box-shadow:var(--shadow-lg);">
        <% } %>
        <div style="font-size:1.05rem;line-height:1.85;color:var(--gray-800);">
            <%- article.contenu %>
        </div>
        <div style="margin-top:48px;padding-top:24px;border-top:1px solid var(--gray-200);">
            <a href="/blog" class="btn btn-ghost">← Retour au blog</a>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
