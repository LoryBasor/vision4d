<%- include('../partials/admin-header') %>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
    <div style="font-size:.85rem;color:var(--gray-600);"><%= locals.total || 0 %> produit<%= (locals.total||0)>1?'s':'' %></div>
    <a href="/admin/boutique/nouveau" class="btn btn-primary">+ Ajouter un produit</a>
</div>

<div class="table-card">
    <table>
        <thead>
            <tr><th>Produit</th><th>Catégorie</th><th>Prix</th><th>Stock</th><th>Statut</th><th>Actions</th></tr>
        </thead>
        <tbody>
            <% if (locals.products && products.length) { %>
            <% products.forEach(function(p){ %>
            <tr>
                <td>
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div style="width:44px;height:44px;border-radius:8px;background:var(--gray-100);overflow:hidden;flex-shrink:0;">
                            <% if (p.image_url) { %>
                            <img src="<%= p.image_url %>" style="width:100%;height:100%;object-fit:cover;">
                            <% } else { %>
                            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">📦</div>
                            <% } %>
                        </div>
                        <div>
                            <div class="td-name"><%= p.nom %></div>
                            <div class="td-email"><%= (p.description||'').substring(0,50) %></div>
                        </div>
                    </div>
                </td>
                <td><span class="badge badge-en-cours"><%= p.categorie %></span></td>
                <td><strong><%= parseInt(p.prix).toLocaleString('fr-FR') %> FCFA</strong></td>
                <td><%= p.stock %></td>
                <td><span class="badge <%= p.is_active ? 'badge-paye' : 'badge-expiree' %>"><%= p.is_active ? 'Actif' : 'Inactif' %></span></td>
                <td>
                    <div style="display:flex;gap:6px;">
                        <a href="/admin/boutique/<%= p.id %>/modifier" class="btn btn-ghost btn-sm">✏️</a>
                        <form action="/admin/boutique/<%= p.id %>/supprimer" method="POST" style="margin:0;">
                            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                            <button class="btn btn-danger btn-sm" data-confirm="Supprimer ce produit ?">🗑️</button>
                        </form>
                    </div>
                </td>
            </tr>
            <% }); %>
            <% } else { %>
            <tr><td colspan="6" style="text-align:center;padding:40px;color:var(--gray-400);">Aucun produit</td></tr>
            <% } %>
        </tbody>
    </table>
    <% if (locals.pages > 1) { %>
    <div class="pagination">
        <% for (var p = 1; p <= pages; p++) { %>
        <a href="/admin/boutique?page=<%= p %>" class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
        <% } %>
    </div>
    <% } %>
</div>

<%- include('../partials/admin-footer') %>
