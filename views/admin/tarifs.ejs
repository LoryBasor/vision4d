<%- include('../partials/admin-header') %>

<div class="form-card" style="max-width:680px;">
    <h2 style="font-family:'Syne',sans-serif;margin-bottom:8px;">💰 Gestion des tarifs par tranches</h2>
    <p style="color:var(--gray-600);font-size:.9rem;margin-bottom:32px;">
        Définissez les frais de service selon le nombre de tranches choisi par le client.
    </p>

    <form action="/admin/tarifs" method="POST">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">

        <div style="display:flex;flex-direction:column;gap:20px;margin-bottom:32px;">
            <% if (locals.tarifs) { tarifs.forEach(function(t, idx){ %>
            <div class="tarif-row" style="background:var(--gray-50);border-radius:10px;padding:24px;border:1.5px solid var(--gray-200);">

                <input type="hidden" name="tarifs[<%= idx %>][nombre_tranches]" value="<%= t.nombre_tranches %>">

                <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:16px;">
                    <div style="font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;min-width:140px;">
                        <%= t.nombre_tranches %> tranche<%= t.nombre_tranches > 1 ? 's' : '' %>
                    </div>
                    <div>
                        <label class="form-label" style="font-size:.8rem;">Frais de service (%)</label>
                        <input type="number"
                            name="tarifs[<%= idx %>][frais_pourcent]"
                            value="<%= t.frais_pourcent %>"
                            min="0" max="50" step="0.5"
                            class="form-control frais-input"
                            data-nb="<%= t.nombre_tranches %>"
                            style="max-width:120px;">
                    </div>
                    <div style="flex:1;min-width:200px;">
                        <label class="form-label" style="font-size:.8rem;">Description</label>
                        <input type="text"
                            name="tarifs[<%= idx %>][description]"
                            value="<%= t.description || '' %>"
                            class="form-control"
                            placeholder="Description optionnelle">
                    </div>
                </div>

                <div style="display:flex;gap:24px;flex-wrap:wrap;">
                    <% var formules = [{nom:'ACCESS',prix:5000},{nom:'ESSENTIEL+',prix:8000},{nom:'TOUT CANAL+',prix:15000}]; %>
                    <% formules.forEach(function(f){ %>
                    <div>
                        <div style="font-size:.72rem;color:var(--gray-400);text-transform:uppercase;font-weight:600;"><%= f.nom %></div>
                        <div class="tarif-result"
                             style="font-weight:700;color:var(--teal);font-size:.9rem;"
                             data-base="<%= f.prix %>"
                             data-nb="<%= t.nombre_tranches %>">
                            <%= Math.ceil(f.prix * (1 + t.frais_pourcent/100) / t.nombre_tranches).toLocaleString('fr-FR') %> FCFA/tranche
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% }); } %>
        </div>

        <div style="background:rgba(92,191,190,.08);border:1.5px solid var(--teal);border-radius:10px;padding:16px;margin-bottom:24px;">
            <p style="font-size:.85rem;color:var(--navy);">
                ℹ️ <strong>Note :</strong> Les frais sont appliqués sur le montant total.
                Exemple: 5% sur 8 000 FCFA = 8 400 FCFA total, soit 2 800 FCFA/tranche pour 3 tranches.
            </p>
        </div>

        <button type="submit" class="btn btn-primary">💾 Enregistrer les tarifs</button>
    </form>
</div>

<script>
document.querySelectorAll('.frais-input').forEach(function(input) {
    input.addEventListener('input', function() {
        var nb    = parseInt(this.dataset.nb) || 1;
        var frais = parseFloat(this.value) || 0;
        var row   = this.closest('.tarif-row');
        row.querySelectorAll('.tarif-result').forEach(function(el) {
            var base = parseFloat(el.dataset.base) || 0;
            var par  = Math.ceil(base * (1 + frais / 100) / nb);
            el.textContent = par.toLocaleString('fr-FR') + ' FCFA/tranche';
        });
    });
});
</script>

<%- include('../partials/admin-footer') %>
