<%- include('../partials/admin-header') %>

<div style="max-width:600px;">

    <!-- Statut de connexion -->
    <div class="table-card" style="padding:28px;margin-bottom:24px;">
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;">
            <div style="width:48px;height:48px;border-radius:12px;background:rgba(92,191,190,.12);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0;">
                💬
            </div>
            <div>
                <h2 class="table-title">WhatsApp — Connexion</h2>
                <p style="font-size:.85rem;color:var(--gray-600);margin-top:2px;">
                    Scannez le QR code pour connecter votre compte WhatsApp
                </p>
            </div>
        </div>

        <!-- Badge statut -->
        <div style="margin-bottom:20px;">
            <% if (waStatus === 'connected') { %>
            <div style="display:flex;align-items:center;gap:10px;padding:14px 18px;background:rgba(34,197,94,.08);border-radius:10px;border:1.5px solid rgba(34,197,94,.2);">
                <div style="width:10px;height:10px;border-radius:50%;background:#22c55e;flex-shrink:0;box-shadow:0 0 0 3px rgba(34,197,94,.2);"></div>
                <div>
                    <div style="font-weight:700;color:#15803d;">WhatsApp connecté ✅</div>
                    <div style="font-size:.82rem;color:#166534;margin-top:2px;">
                        Les notifications sont envoyées automatiquement au numéro : <strong><%= process.env.WHATSAPP_ADMIN_NUMBER || 'non configuré' %></strong>
                    </div>
                </div>
            </div>
            <% } else if (waStatus === 'qr_ready') { %>
            <div style="display:flex;align-items:center;gap:10px;padding:14px 18px;background:rgba(251,191,36,.08);border-radius:10px;border:1.5px solid rgba(251,191,36,.3);">
                <div style="width:10px;height:10px;border-radius:50%;background:#f59e0b;flex-shrink:0;animation:pulse 1.5s infinite;"></div>
                <div>
                    <div style="font-weight:700;color:#b45309;">En attente de scan 📱</div>
                    <div style="font-size:.82rem;color:#92400e;margin-top:2px;">
                        Scannez le QR code ci-dessous avec votre WhatsApp
                    </div>
                </div>
            </div>
            <% } else { %>
            <div style="display:flex;align-items:center;gap:10px;padding:14px 18px;background:rgba(100,116,139,.06);border-radius:10px;border:1.5px solid rgba(100,116,139,.2);">
                <div style="width:10px;height:10px;border-radius:50%;background:var(--gray-400);flex-shrink:0;"></div>
                <div>
                    <div style="font-weight:700;color:var(--gray-600);">WhatsApp déconnecté</div>
                    <div style="font-size:.82rem;color:var(--gray-400);margin-top:2px;">
                        <% if (waError) { %>
                        Erreur : <%= waError %>
                        <% } else { %>
                        Le service démarre... Rechargez cette page dans quelques secondes.
                        <% } %>
                    </div>
                </div>
            </div>
            <% } %>
        </div>

        <!-- QR Code -->
        <% if (waStatus === 'qr_ready' && qrCode) { %>
        <div style="text-align:center;padding:24px;background:var(--gray-50);border-radius:12px;border:1.5px dashed var(--gray-200);">
            <p style="font-size:.85rem;color:var(--gray-600);margin-bottom:16px;">
                📱 Ouvrez <strong>WhatsApp</strong> sur votre téléphone →
                <strong>Appareils connectés</strong> → <strong>Connecter un appareil</strong>
            </p>
            <img src="<%= qrCode %>" alt="QR Code WhatsApp"
                 style="width:220px;height:220px;border-radius:12px;box-shadow:var(--shadow);">
            <p style="font-size:.78rem;color:var(--gray-400);margin-top:12px;">
                ⚠️ Le QR code expire en 60 secondes — rechargez la page si nécessaire
            </p>
            <!-- Auto-refresh toutes les 30 secondes -->
            <script>
            setTimeout(function() {
                window.location.reload();
            }, 30000);
            </script>
        </div>
        <% } %>

        <!-- Actions -->
        <div style="display:flex;gap:10px;margin-top:20px;flex-wrap:wrap;">
            <a href="/admin/whatsapp" class="btn btn-ghost btn-sm">🔄 Actualiser le statut</a>
            <% if (waStatus !== 'connected') { %>
            <form action="/admin/whatsapp/restart" method="POST" style="margin:0;">
                <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                <button class="btn btn-primary btn-sm">▶️ Redémarrer WhatsApp</button>
            </form>
            <% } %>
            <% if (waStatus === 'connected') { %>
            <form action="/admin/whatsapp/test" method="POST" style="margin:0;">
                <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                <button class="btn btn-sm" style="background:#25d366;color:#fff;">📤 Envoyer message test</button>
            </form>
            <% } %>
        </div>
    </div>

    <!-- Configuration -->
    <div class="form-card" style="padding:24px;">
        <h3 style="font-family:'Syne',sans-serif;font-size:1rem;margin-bottom:16px;">⚙️ Configuration</h3>
        <div style="font-size:.875rem;display:flex;flex-direction:column;gap:10px;">
            <div style="display:flex;justify-content:space-between;padding:10px 14px;background:var(--gray-50);border-radius:8px;">
                <span style="color:var(--gray-600);">Numéro admin</span>
                <strong><%= process.env.WHATSAPP_ADMIN_NUMBER || '❌ Non configuré dans .env' %></strong>
            </div>
            <div style="display:flex;justify-content:space-between;padding:10px 14px;background:var(--gray-50);border-radius:8px;">
                <span style="color:var(--gray-600);">Statut technique</span>
                <strong style="color:<%= waStatus === 'connected' ? '#15803d' : waStatus === 'qr_ready' ? '#b45309' : 'var(--gray-600)' %>">
                    <%= waStatus %>
                </strong>
            </div>
        </div>

        <div style="margin-top:16px;padding:14px;background:rgba(92,191,190,.06);border-radius:8px;border-left:3px solid var(--teal);font-size:.82rem;color:var(--navy);">
            <strong>💡 Sur Render :</strong> Ajoutez la variable d'environnement
            <code style="background:rgba(0,0,0,.06);padding:2px 6px;border-radius:4px;">PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser</code>
            et activez le buildpack Puppeteer.
        </div>
    </div>

</div>

<style>
@keyframes pulse {
    0%, 100% { opacity:1; transform:scale(1); }
    50%       { opacity:.5; transform:scale(1.3); }
}
</style>

<%- include('../partials/admin-footer') %>
