<%- include('../partials/admin-header') %>

<style>
@keyframes blink { 0%,100%{opacity:1}50%{opacity:.3} }
@keyframes spin  { to{transform:rotate(360deg)} }
.dot { width:10px;height:10px;border-radius:50%;flex-shrink:0; }
.dot.green  { background:#25d366; }
.dot.yellow { background:#f59e0b;animation:blink 1s infinite; }
.dot.red    { background:var(--red); }
</style>

<div style="max-width:520px;">

    <div style="margin-bottom:24px;">
        <h2 style="font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;">💬 WhatsApp</h2>
        <p style="color:var(--gray-600);font-size:.875rem;margin-top:4px;">
            Notifications automatiques via Baileys
        </p>
    </div>

    <!-- ══ CONNECTÉ ══════════════════════════════════════════════ -->
    <% if (waStatus === 'connected') { %>

    <div class="table-card" style="padding:28px;margin-bottom:16px;border-left:4px solid #25d366;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
            <div class="dot green"></div>
            <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:1rem;color:#15803d;">Connecté</div>
        </div>

        <div style="font-size:.875rem;color:var(--gray-600);margin-bottom:20px;">
            Les messages sont envoyés automatiquement au numéro :
            <strong style="color:var(--navy);display:block;margin-top:4px;font-size:1rem;">
                📱 <%= process.env.WHATSAPP_ADMIN_NUMBER || '—' %>
            </strong>
        </div>

        <!-- Bouton test -->
        <form action="/admin/whatsapp/test" method="POST" style="margin-bottom:12px;">
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
            <button class="btn" style="background:#25d366;color:#fff;width:100%;justify-content:center;">
                📤 Envoyer un message test
            </button>
        </form>

        <!-- Déconnecter -->
        <form action="/admin/whatsapp/restart" method="POST">
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
            <button class="btn btn-ghost btn-sm" style="width:100%;justify-content:center;color:var(--gray-400);"
                    onclick="return confirm('Déconnecter WhatsApp ?')">
                Déconnecter la session
            </button>
        </form>
    </div>

    <!-- ══ QR EN ATTENTE ════════════════════════════════════════ -->
    <% } else if (waStatus === 'qr_ready' && qrCode) { %>

    <div class="table-card" style="padding:28px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
            <div class="dot yellow"></div>
            <div style="font-weight:700;color:#b45309;">En attente du scan</div>
        </div>

        <!-- QR Code centré -->
        <div style="text-align:center;margin-bottom:20px;">
            <div style="display:inline-block;padding:12px;background:#fff;border-radius:12px;box-shadow:0 2px 16px rgba(1,24,38,.12);">
                <img src="<%= qrCode %>" alt="QR WhatsApp" style="width:220px;height:220px;display:block;">
            </div>
        </div>

        <!-- Instructions courtes -->
        <ol style="font-size:.875rem;color:var(--gray-600);padding-left:20px;line-height:2;margin-bottom:20px;">
            <li>Ouvrez <strong>WhatsApp</strong> sur votre téléphone</li>
            <li>Allez dans <strong>Appareils connectés</strong></li>
            <li>Appuyez sur <strong>Connecter un appareil</strong></li>
            <li>Scannez ce QR code</li>
        </ol>

        <div style="display:flex;gap:10px;">
            <a href="/admin/whatsapp" class="btn btn-ghost btn-sm" style="flex:1;justify-content:center;">
                🔄 Actualiser
            </a>
            <form action="/admin/whatsapp/restart" method="POST" style="flex:1;margin:0;">
                <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                <button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;">
                    Nouveau QR
                </button>
            </form>
        </div>
    </div>

    <!-- ══ DÉMARRAGE / ERREUR ════════════════════════════════════ -->
    <% } else { %>

    <div class="table-card" style="padding:28px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
            <% if (waError) { %>
            <div class="dot red"></div>
            <div style="font-weight:700;color:var(--red);">Erreur</div>
            <% } else { %>
            <div style="width:10px;height:10px;border:2px solid var(--gray-200);border-top-color:var(--teal);border-radius:50%;animation:spin 1s linear infinite;flex-shrink:0;"></div>
            <div style="font-weight:700;color:var(--gray-600);">Démarrage...</div>
            <% } %>
        </div>

        <% if (waError) { %>
        <div style="padding:12px 16px;background:rgba(231,23,74,.06);border-radius:8px;font-size:.85rem;color:var(--red);margin-bottom:16px;border-left:3px solid var(--red);">
            <%= waError %>
        </div>
        <% } else { %>
        <p style="font-size:.875rem;color:var(--gray-600);margin-bottom:16px;">
            Baileys initialise la connexion WhatsApp. Le QR code apparaîtra ici.
        </p>
        <% } %>

        <div style="display:flex;gap:10px;">
            <a href="/admin/whatsapp" class="btn btn-ghost btn-sm" style="flex:1;justify-content:center;">
                🔄 Actualiser
            </a>
            <form action="/admin/whatsapp/restart" method="POST" style="flex:1;margin:0;">
                <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                <button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;">
                    ▶️ Démarrer
                </button>
            </form>
        </div>
    </div>

    <% } %>

    <!-- Infos numéro -->
    <div style="padding:14px 18px;background:var(--gray-50);border-radius:10px;border:1.5px solid var(--gray-200);font-size:.82rem;color:var(--gray-600);">
        <div style="margin-bottom:6px;">
            Numéro configuré :
            <strong style="color:<%= process.env.WHATSAPP_ADMIN_NUMBER ? 'var(--navy)' : 'var(--red)' %>">
                <%= process.env.WHATSAPP_ADMIN_NUMBER || '❌ Non défini dans .env' %>
            </strong>
        </div>
        <div style="font-size:.75rem;color:var(--gray-400);">
            Variable <code>WHATSAPP_ADMIN_NUMBER</code> dans <code>.env</code>
            — format : indicatif + numéro (ex: <code>237690000000</code>)
        </div>
    </div>

</div>

<%- include('../partials/admin-footer') %>
