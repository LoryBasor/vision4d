<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — Connexion Vision 4D</title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        body {
            justify-content: center;
            align-items: center;
            background: var(--navy);
            min-height: 100vh;
            margin-left: 0 !important;
        }
        .admin-main { margin-left: 0 !important; }
        .login-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 40px 24px;
        }
        .login-box {
            background: var(--white);
            border-radius: 16px;
            padding: 48px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 24px 64px rgba(0,0,0,.3);
        }
    </style>
</head>
<body style="display:block;background:var(--navy);">

<div class="login-wrap">
    <div class="login-box">
        <div style="text-align:center;margin-bottom:36px;">
            <img src="/images/logo.png" alt="Vision 4D"
                 style="height:52px;width:auto;object-fit:contain;display:block;margin:0 auto 12px;"
                 onerror="this.outerHTML='<div style=\'width:52px;height:52px;background:var(--teal);border-radius:14px;display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-family:Syne,sans-serif;font-size:1rem;margin:0 auto 12px;\'>V4</div>';">
            <h1 style="font-family:'Syne',sans-serif;font-size:1.4rem;color:var(--navy);">Administration</h1>
            <p style="color:var(--gray-600);font-size:.875rem;margin-top:4px;">Espace réservé aux administrateurs</p>
        </div>

        <% if (locals.errors && errors.length) { %>
        <% errors.forEach(function(e){ %>
        <div class="alert alert-error"><%= e.msg %></div>
        <% }); %>
        <% } %>

        <form action="/admin/connexion" method="POST">
            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
            <div class="form-group">
                <label class="form-label">Email admin</label>
                <input type="email" name="email" class="form-control"
                    value="<%= locals.old && old.email ? old.email : '' %>"
                    placeholder="admin@vision4d.cm" required>
            </div>
            <div class="form-group">
                <label class="form-label">Mot de passe</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:13px;">
                Se connecter
            </button>
        </form>

        <div style="margin-top:24px;text-align:center;">
            <a href="/" style="font-size:.85rem;color:var(--gray-400);">← Retour au site</a>
        </div>
    </div>
</div>

<script src="/js/admin.js"></script>
</body>
</html>
