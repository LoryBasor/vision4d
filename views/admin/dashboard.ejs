<%- include('../partials/admin-header') %>

<div class="stats-row">
    <div class="stat-card">
        <div class="icon-box teal">👥</div>
        <div class="info"><div class="label">Clients actifs</div><div class="value"><%= locals.totalUsers || 0 %></div></div>
    </div>
    <div class="stat-card">
        <div class="icon-box orange">📺</div>
        <div class="info"><div class="label">Abonnements actifs</div><div class="value"><%= locals.subStats ? subStats.en_cours : 0 %></div></div>
    </div>
    <div class="stat-card">
        <div class="icon-box green">✅</div>
        <div class="info"><div class="label">Abonnements terminés</div><div class="value"><%= locals.subStats ? subStats.completes : 0 %></div></div>
    </div>
    <div class="stat-card">
        <div class="icon-box teal">💰</div>
        <div class="info">
            <div class="label">Revenus totaux</div>
            <div class="value" style="font-size:1.3rem;"><%= locals.revenue ? parseInt(revenue).toLocaleString('fr-FR') : 0 %></div>
            <div class="sub">FCFA</div>
        </div>
    </div>
</div>

<div class="table-card">
    <div class="table-header">
        <h2 class="table-title">💳 Paiements récents</h2>
        <a href="/admin/abonnements" class="btn btn-ghost btn-sm">Voir tout →</a>
    </div>
    <% if (locals.recentPayments && recentPayments.length) { %>
    <div style="overflow-x:auto;">
    <table>
        <thead>
            <tr><th>Client</th><th>Formule</th><th>Tranche</th><th>Montant</th><th>Date</th><th>Statut</th></tr>
        </thead>
        <tbody>
            <% recentPayments.forEach(function(p){ %>
            <tr>
                <td>
                    <div class="td-user">
                        <div class="td-avatar" style="background:var(--teal);color:#fff;font-weight:700;">
                            <%= (p.client_nom || 'U').charAt(0).toUpperCase() %>
                        </div>
                        <div><div class="td-name"><%= p.client_nom %></div><div class="td-email"><%= p.telephone %></div></div>
                    </div>
                </td>
                <td><strong>Canal+ <%= p.formule_nom %></strong></td>
                <td>Tranche <%= p.numero_tranche %></td>
                <td><strong><%= parseInt(p.montant).toLocaleString('fr-FR') %> FCFA</strong></td>
                <td><%= p.date_paiement ? new Date(p.date_paiement).toLocaleDateString('fr-FR') : '—' %></td>
                <td><span class="badge badge-paye">Payé</span></td>
            </tr>
            <% }); %>
        </tbody>
    </table>
    </div>
    <% } else { %>
    <div style="padding:40px;text-align:center;color:var(--gray-400);">Aucun paiement enregistré.</div>
    <% } %>
</div>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:24px;">
    <a href="/admin/clients" class="stat-card" style="text-decoration:none;">
        <div class="icon-box teal">👥</div><div class="info"><div class="label">Accès rapide</div><div style="font-weight:600;font-size:.9rem;">Gérer les clients</div></div>
    </a>
    <a href="/admin/abonnements" class="stat-card" style="text-decoration:none;">
        <div class="icon-box orange">📺</div><div class="info"><div class="label">Accès rapide</div><div style="font-weight:600;font-size:.9rem;">Abonnements</div></div>
    </a>
    <a href="/admin/articles/nouveau" class="stat-card" style="text-decoration:none;">
        <div class="icon-box teal">✍️</div><div class="info"><div class="label">Accès rapide</div><div style="font-weight:600;font-size:.9rem;">Nouvel article</div></div>
    </a>
    <a href="/admin/boutique/nouveau" class="stat-card" style="text-decoration:none;">
        <div class="icon-box green">📦</div><div class="info"><div class="label">Accès rapide</div><div style="font-weight:600;font-size:.9rem;">Ajouter produit</div></div>
    </a>
</div>

<%- include('../partials/admin-footer') %>
