<%- include('../partials/admin-header') %>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
    <a href="/admin/clients" class="btn btn-ghost btn-sm">← Retour aux clients</a>
    <!-- Bouton activer/désactiver le client -->
    <form action="/admin/clients/<%= user.id %>/toggle-active" method="POST" style="margin:0;">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
        <button class="btn btn-sm <%= user.is_active ? 'btn-danger' : 'btn-primary' %>"
                onclick="return confirm('<%= user.is_active ? 'Désactiver ce client ?' : 'Activer ce client ?' %>')">
            <%= user.is_active ? '🔒 Désactiver le compte' : '✅ Activer le compte' %>
        </button>
    </form>
</div>

<div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;align-items:start;">

    <!-- Profil client -->
    <div class="table-card" style="padding:28px;">
        <div style="text-align:center;margin-bottom:24px;">
            <div style="width:80px;height:80px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;color:#fff;margin:0 auto 12px;overflow:hidden;border:3px solid #fff;box-shadow:0 0 0 3px var(--teal);">
                <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" alt="<%= user.prenom %>" style="width:100%;height:100%;object-fit:cover;">
                <% } else { %>
                <%= user.prenom.charAt(0) %><%= user.nom.charAt(0) %>
                <% } %>
            </div>
            <div style="font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;"><%= user.prenom %> <%= user.nom %></div>
            <div style="margin-top:6px;">
                <span class="badge <%= user.is_active ? 'badge-paye' : 'badge-expiree' %>">
                    <%= user.is_active ? '✅ Actif' : '🔒 Désactivé' %>
                </span>
            </div>
            <div style="font-size:.82rem;color:var(--gray-500);margin-top:6px;">
                Client depuis <%= new Date(user.created_at).toLocaleDateString('fr-FR') %>
            </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:10px;font-size:.875rem;">
            <div style="padding:10px;background:var(--gray-50);border-radius:8px;">
                <span style="color:var(--gray-600);">📧</span> <%= user.email %>
            </div>
            <div style="padding:10px;background:var(--gray-50);border-radius:8px;">
                <span style="color:var(--gray-600);">📱</span> <%= user.telephone %>
            </div>
            <div style="padding:10px;background:var(--gray-50);border-radius:8px;">
                <span style="color:var(--gray-600);">📺</span>
                <% if (user.numero_decodeur) { %>
                    <strong><%= user.numero_decodeur %></strong>
                <% } else { %>
                    <span style="color:var(--gray-400);font-style:italic;">Décodeur non renseigné</span>
                <% } %>
            </div>
        </div>

        <% if (user.telephone) { %>
        <a href="https://wa.me/<%= user.telephone.replace(/\D/g,'') %>" target="_blank"
           class="btn btn-primary" style="width:100%;justify-content:center;margin-top:20px;">
            💬 Contacter sur WhatsApp
        </a>
        <% } %>
    </div>

    <!-- Abonnements -->
    <div>
        <div class="table-card" style="margin-bottom:16px;">
            <div class="table-header">
                <h2 class="table-title">📺 Abonnements</h2>
                <span style="font-size:.82rem;color:var(--gray-600);">
                    <%= locals.subscriptions ? subscriptions.length : 0 %> abonnement<%= (locals.subscriptions && subscriptions.length > 1) ? 's' : '' %>
                </span>
            </div>

            <% if (locals.subscriptions && subscriptions.length) { %>
            <table>
                <thead>
                    <tr>
                        <th>Formule</th>
                        <th>Progression</th>
                        <th>Montant</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% subscriptions.forEach(function(sub){ %>
                    <tr>
                        <td><strong>Canal+ <%= sub.formule_nom %></strong></td>
                        <td>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div style="flex:1;height:6px;background:var(--gray-200);border-radius:99px;overflow:hidden;min-width:60px;">
                                    <div style="height:100%;width:<%= Math.round((sub.tranches_payees/sub.nombre_tranches)*100) %>%;background:var(--teal);border-radius:99px;"></div>
                                </div>
                                <span style="font-size:.78rem;white-space:nowrap;color:var(--gray-600);">
                                    <%= sub.tranches_payees %>/<%= sub.nombre_tranches %>
                                </span>
                            </div>
                        </td>
                        <td><%= parseInt(sub.montant_total).toLocaleString('fr-FR') %> FCFA</td>
                        <td>
                            <span class="badge badge-<%= sub.statut.replace(/_/g,'-') %>">
                                <%= sub.statut.replace(/_/g,' ') %>
                            </span>
                        </td>
                        <td style="font-size:.8rem;"><%= new Date(sub.created_at).toLocaleDateString('fr-FR') %></td>
                        <td>
                            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                <a href="/admin/abonnements/<%= sub.id %>" class="btn btn-ghost btn-sm">
                                    ✏️ Gérer
                                </a>
                                <form action="/admin/clients/<%= user.id %>/supprimer-abonnement" method="POST" style="margin:0;">
                                    <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                                    <input type="hidden" name="subscription_id" value="<%= sub.id %>">
                                    <button class="btn btn-danger btn-sm" data-confirm="Supprimer définitivement cet abonnement ?">
                                        🗑️
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% } else { %>
            <div style="padding:32px;text-align:center;color:var(--gray-400);">
                <div style="font-size:2rem;margin-bottom:8px;">📭</div>
                Aucun abonnement pour ce client
            </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/admin-footer') %>
