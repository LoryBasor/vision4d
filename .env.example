# ================================
# VISION 4D — Variables d'environnement
# ================================

# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=vision4d

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Session
SESSION_SECRET=your_session_secret_key_change_this_in_production

# Bcrypt
BCRYPT_ROUNDS=12

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Monetbil
MONETBIL_SERVICE_KEY=your_monetbil_service_key
MONETBIL_SERVICE_SECRET=your_monetbil_service_secret
MONETBIL_NOTIFY_URL=http://localhost:3000/payment/notify
MONETBIL_RETURN_URL=http://localhost:3000/payment/return

# WhatsApp Admin
WHATSAPP_ADMIN_NUMBER=237600000000
ADMIN_WHATSAPP_LINK=https://wa.me/237600000000

# Admin par défaut
ADMIN_EMAIL=admin@vision4d.cm
ADMIN_PASSWORD=Admin@2024
ADMIN_NAME=Administrateur

# Délai paiement tranches (en jours)
PAYMENT_DEADLINE_DAYS=15
